# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://admin:1212@localhost:5432/agent_platform

# ─── Redis (Celery broker + result backend) ──────────────────
REDIS_URL=redis://localhost:6379/0

# ─── JWT Auth ────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── CORS ────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]

# ─── OpenAI ──────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4

# ─── App ─────────────────────────────────────────────────────
DEBUG=false

GENERATION_TOP_P=0.9
GENERATION_MAX_CONTEXT_LENGTH=8000

# Search Provider Configuration
# SerpAPI for Google Search and other search engines
SERPAPI_API_KEY=your_serpapi_api_key_here

# Bing Search API
BING_SEARCH_API_KEY=your_bing_search_api_key_here

# DuckDuckGo is free and doesn't require an API key!
